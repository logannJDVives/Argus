@page "/projects"
@inject ArgusApiClient Api
@inject AuthStateService Auth
@inject NavigationManager Nav

<div class="page-header mb-5">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="mb-1">Projects</h2>
            <p class="text-muted mb-0">Manage and scan your uploaded projects.</p>
        </div>
        <a href="upload" class="btn btn-primary">Upload project</a>
    </div>
</div>

@if (_loading)
{
    <div class="state-loading">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Loading projects…</p>
    </div>
}
else if (_errorMessage is not null)
{
    <div class="alert alert-danger">@_errorMessage</div>
}
else if (_projects.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon">📂</div>
        <h3 class="empty-state-title">No projects yet</h3>
        <p class="empty-state-desc">Upload a ZIP archive to start scanning for secrets and dependencies.</p>
        <a href="upload" class="btn btn-primary px-4">Upload your first project</a>
    </div>
}
else
{
    <div class="project-list">
        @foreach (var project in _projects)
        {
            <div class="project-card">
                <div class="project-card-main">

                    <div class="project-card-info">
                        @if (_editingProjectId == project.Id)
                        {
                            <input class="form-control form-control-sm project-rename-input"
                                   @bind="_editName"
                                   @bind:event="oninput"
                                   @onkeydown="e => OnRenameKeyDown(e, project)"
                                   placeholder="Project name" />
                        }
                        else
                        {
                            <div class="project-name">@project.Name</div>
                        }
                        <div class="project-meta">
                            <span>Created @project.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</span>
                            @if (project.LastScanDate.HasValue)
                            {
                                <span class="project-meta-sep">·</span>
                                <span>Last scan @project.LastScanDate.Value.ToLocalTime().ToString("dd MMM yyyy")</span>
                            }
                            <span class="project-meta-sep">·</span>
                            <span>@project.ScanRunCount scan@(project.ScanRunCount == 1 ? "" : "s")</span>
                        </div>
                    </div>

                    <div class="project-card-actions">
                        @if (_editingProjectId == project.Id)
                        {
                            <button class="btn btn-sm btn-primary"
                                    @onclick="() => HandleRenameAsync(project)"
                                    disabled="@(string.IsNullOrWhiteSpace(_editName))">
                                Save
                            </button>
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="CancelRename">
                                Cancel
                            </button>
                        }
                        else if (_confirmDeleteId == project.Id)
                        {
                            <span class="text-danger small fw-medium me-1">Delete "@project.Name"?</span>
                            <button class="btn btn-sm btn-danger me-1"
                                    @onclick="() => HandleDeleteAsync(project)">
                                Delete
                            </button>
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="() => _confirmDeleteId = null">
                                Cancel
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-primary"
                                    @onclick="() => StartScanAsync(project)"
                                    disabled="@(_scanningProjectId == project.Id)">
                                @if (_scanningProjectId == project.Id)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                    <span>Scanning…</span>
                                }
                                else
                                {
                                    <span>▶ Scan</span>
                                }
                            </button>
                            @if (project.ScanRunCount > 0)
                            {
                                <a href="projects/@project.Id/scans" class="btn btn-sm btn-outline-secondary">History</a>
                            }
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="() => StartRename(project)">
                                Rename
                            </button>
                            <button class="btn btn-sm btn-ghost-danger"
                                    @onclick="() => { _confirmDeleteId = project.Id; _editingProjectId = null; }">
                                Delete
                            </button>
                        }
                    </div>

                </div>
            </div>
        }
    </div>
}

@if (_scanError is not null)
{
    <div class="alert alert-danger mt-4">@_scanError</div>
}

@if (_actionError is not null)
{
    <div class="alert alert-danger mt-4">@_actionError</div>
}

@code {
    private List<ProjectDto> _projects = [];
    private bool    _loading;
    private string? _errorMessage;
    private string? _scanError;
    private string? _actionError;
    private Guid?   _scanningProjectId;
    private Guid?   _editingProjectId;
    private string  _editName       = string.Empty;
    private Guid?   _confirmDeleteId;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsAuthenticated)
        {
            Nav.NavigateTo("/login");
            return;
        }

        _loading = true;
        try
        {
            _projects = await Api.GetProjectsAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load projects: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnRenameKeyDown(KeyboardEventArgs e, ProjectDto project)
    {
        if (e.Key == "Enter")       await HandleRenameAsync(project);
        else if (e.Key == "Escape") CancelRename();
    }

    private void StartRename(ProjectDto project)
    {
        _editingProjectId = project.Id;
        _editName         = project.Name;
        _confirmDeleteId  = null;
        _actionError      = null;
    }

    private void CancelRename()
    {
        _editingProjectId = null;
        _editName         = string.Empty;
    }

    private async Task HandleRenameAsync(ProjectDto project)
    {
        _actionError = null;
        try
        {
            var updated = await Api.UpdateProjectAsync(project.Id, new UpdateProjectDto { Name = _editName.Trim() });
            var index   = _projects.IndexOf(project);
            if (index >= 0) _projects[index] = updated;
            _editingProjectId = null;
            _editName         = string.Empty;
        }
        catch (Exception ex)
        {
            _actionError = $"Rename failed: {ex.Message}";
        }
    }

    private async Task HandleDeleteAsync(ProjectDto project)
    {
        _actionError = null;
        try
        {
            await Api.DeleteProjectAsync(project.Id);
            _projects.Remove(project);
            _confirmDeleteId = null;
        }
        catch (Exception ex)
        {
            _actionError = $"Delete failed: {ex.Message}";
        }
    }

    private async Task StartScanAsync(ProjectDto project)
    {
        _scanningProjectId = project.Id;
        _scanError         = null;
        try
        {
            var scan = await Api.StartScanAsync(project.Id);
            Nav.NavigateTo($"projects/{project.Id}/scans/{scan.Id}");
        }
        catch (Exception ex)
        {
            _scanError = $"Scan failed for '{project.Name}': {ex.Message}";
        }
        finally
        {
            _scanningProjectId = null;
        }
    }
}
