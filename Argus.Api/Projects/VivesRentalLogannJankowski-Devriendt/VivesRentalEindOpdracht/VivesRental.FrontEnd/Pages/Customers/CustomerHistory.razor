@page "/customers/{Id:guid}/history"

<PageTitle>Verhuurgeschiedenis - VivesRental</PageTitle>

<link href="css/pages/customer-history.css" rel="stylesheet" />

<h1>Verhuurgeschiedenis</h1>

@if (_loading)
{
    <p>Laden...</p>
}
else if (_error != null)
{
    <div class="alert alert-danger">@_error</div>
    <a href="/customers" class="btn btn-secondary">Terug naar klanten</a>
}
else if (_customer != null)
{
    <!-- Klant informatie -->
    <div class="customer-header">
        <h2>@_customer.FirstName @_customer.LastName</h2>
        <div class="customer-info">
            <div class="customer-info-item">
                <label>Email</label>
                <span>@_customer.Email</span>
            </div>
            <div class="customer-info-item">
                <label>Telefoon</label>
                <span>@_customer.PhoneNumber</span>
            </div>
            <div class="customer-info-item">
                <label>Klant ID</label>
                <span class="text-muted" style="font-family: monospace; font-size: 0.85rem;">@_customer.Id</span>
            </div>
        </div>
    </div>

    <!-- Statistieken -->
    <div class="history-stats">
        <div class="history-stat">
            <h4>@_customerOrders.Count</h4>
            <p>Totaal Orders</p>
        </div>
        <div class="history-stat @(_overdueCount > 0 ? "danger" : "")">
            <h4>@_overdueCount</h4>
            <p>Te laat teruggebracht</p>
        </div>
        <div class="history-stat @(_ontimeCount > 0 ? "success" : "")">
            <h4>@_ontimeCount</h4>
            <p>Op tijd teruggebracht</p>
        </div>
        <div class="history-stat warning">
            <h4>@_activeCount</h4>
            <p>Nog actief</p>
        </div>
    </div>

    @if (_overdueCount > 2)
    {
        <div class="alert alert-danger">
            <strong>Let op!</strong> Deze klant heeft @_overdueCount keer te laat materiaal teruggebracht.
        </div>
    }
    else if (_overdueCount > 0)
    {
        <div class="alert alert-warning">
            <strong>Opmerking:</strong> Deze klant heeft @_overdueCount keer te laat materiaal teruggebracht.
        </div>
    }

    <!-- Terug knop -->
    <div class="mb-3">
        <a href="/customers" class="btn btn-secondary">Terug naar klanten</a>
        <a href="/orders/new" class="btn btn-primary">Nieuwe verhuur voor deze klant</a>
    </div>

    <!-- Order geschiedenis -->
    <h3>Orders (@_customerOrders.Count)</h3>

    @if (_customerOrders.Count == 0)
    {
        <p class="text-muted">Deze klant heeft nog geen orders.</p>
    }
    else
    {
        <div class="history-list">
            @foreach (var order in _customerOrders.OrderByDescending(o => o.CreatedAt))
            {
                var orderLines = _orderLines.Where(ol => ol.OrderId == order.Id).ToList();
                var hasOverdue = orderLines.Any(ol => ol.ReturnedAt.HasValue && ol.ReturnedAt > ol.ExpiresAt);
                var isActive = !order.ReturnedAt.HasValue && orderLines.Any(ol => !ol.ReturnedAt.HasValue);

                <div class="history-item @(hasOverdue ? "has-overdue" : "all-ontime")">
                    <div class="history-item-header">
                        <h5>Order #@order.Id.ToString()[..8]...</h5>
                        <div>
                            @if (order.ReturnedAt.HasValue)
                            {
                                @if (hasOverdue)
                                {
                                    <span class="badge bg-danger">Te laat teruggebracht</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Op tijd teruggebracht</span>
                                }
                            }
                            else if (isActive)
                            {
                                <span class="badge bg-primary">Actief</span>
                            }
                        </div>
                    </div>
                    <div class="history-item-details">
                        <strong>Aangemaakt:</strong> @order.CreatedAt.ToString("dd-MM-yyyy HH:mm")
                        @if (order.ReturnedAt.HasValue)
                        {
                            <span> | <strong>Teruggebracht:</strong> @order.ReturnedAt.Value.ToString("dd-MM-yyyy HH:mm")</span>
                        }
                        <span> | <strong>Items:</strong> @order.NumberOfOrderLines</span>
                    </div>

                    @if (orderLines.Count > 0)
                    {
                        <div class="history-orderlines">
                            @foreach (var line in orderLines)
                            {
                                var lineOverdue = line.ReturnedAt.HasValue && line.ReturnedAt > line.ExpiresAt;
                                var lineActive = !line.ReturnedAt.HasValue;

                                <div class="orderline-item @(lineOverdue ? "overdue" : lineActive ? "" : "ontime")">
                                    <span>@line.ProductName</span>
                                    <span>
                                        @if (lineOverdue)
                                        {
                                            <span>Te laat (@((line.ReturnedAt!.Value - line.ExpiresAt).Days) dagen)</span>
                                        }
                                        else if (lineActive)
                                        {
                                            <span>Nog niet teruggebracht</span>
                                        }
                                        else
                                        {
                                            <span>Op tijd</span>
                                        }
                                    </span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    [Inject] private ICustomerSdk CustomerSdk { get; set; } = default!;
    [Inject] private IOrderSdk OrderSdk { get; set; } = default!;
    [Inject] private IOrderLineSdk OrderLineSdk { get; set; } = default!;

    private CustomerResult? _customer;
    private IList<OrderResult> _customerOrders = new List<OrderResult>();
    private IList<OrderLineResult> _orderLines = new List<OrderLineResult>();
    
    private int _overdueCount;
    private int _ontimeCount;
    private int _activeCount;
    
    private bool _loading = true;
    private string? _error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = null;

        try
        {
            _customer = await CustomerSdk.GetAsync(Id);
            if (_customer == null)
            {
                _error = "Klant niet gevonden.";
                return;
            }

            // Haal alle orders op en filter op klant
            var allOrders = await OrderSdk.FindAsync();
            _customerOrders = allOrders.Where(o => o.CustomerId == Id).ToList();

            // Haal alle orderlines op voor deze orders
            var allOrderLines = await OrderLineSdk.FindAsync();
            var orderIds = _customerOrders.Select(o => o.Id).ToHashSet();
            _orderLines = allOrderLines.Where(ol => orderIds.Contains(ol.OrderId)).ToList();

            // Bereken statistieken
            CalculateStats();
        }
        catch (Exception ex)
        {
            _error = $"Fout bij laden: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void CalculateStats()
    {
        _overdueCount = 0;
        _ontimeCount = 0;
        _activeCount = 0;

        foreach (var order in _customerOrders)
        {
            var orderLines = _orderLines.Where(ol => ol.OrderId == order.Id).ToList();
            
            if (!order.ReturnedAt.HasValue && orderLines.Any(ol => !ol.ReturnedAt.HasValue))
            {
                _activeCount++;
            }
            else if (orderLines.Any(ol => ol.ReturnedAt.HasValue && ol.ReturnedAt > ol.ExpiresAt))
            {
                _overdueCount++;
            }
            else
            {
                _ontimeCount++;
            }
        }
    }
}
