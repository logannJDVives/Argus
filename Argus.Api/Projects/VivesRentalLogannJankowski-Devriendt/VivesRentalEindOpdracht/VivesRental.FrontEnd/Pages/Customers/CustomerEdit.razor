@page "/customers/edit/{Id:guid}"

<PageTitle>Klant Bewerken - VivesRental</PageTitle>

<link href="css/pages/customer-form.css" rel="stylesheet" />

<h1>Klant Bewerken</h1>

<div class="form-container">
    @if (_loading)
    {
        <p>Laden...</p>
    }
    else if (_error != null)
    {
        <div class="alert alert-danger">@_error</div>
    }

    @if (!_loading)
    {
        <EditForm Model="_request" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label for="firstName" class="form-label">Voornaam</label>
                <InputText id="firstName" class="form-control" @bind-Value="_request.FirstName" />
            </div>

            <div class="mb-3">
                <label for="lastName" class="form-label">Achternaam</label>
                <InputText id="lastName" class="form-control" @bind-Value="_request.LastName" />
            </div>

            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <InputText id="email" class="form-control" type="email" @bind-Value="_request.Email" />
            </div>

            <div class="mb-3">
                <label for="phone" class="form-label">Telefoonnummer</label>
                <InputText id="phone" class="form-control" @bind-Value="_request.PhoneNumber" />
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary" disabled="@_saving">
                    @if (_saving) { <span>Opslaan...</span> } else { <span>Opslaan</span> }
                </button>
                <a href="/customers" class="btn btn-secondary">Annuleren</a>
            </div>
        </EditForm>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    [Inject] private ICustomerSdk CustomerSdk { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private CustomerRequest _request = new();
    private bool _loading = true;
    private bool _saving;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var customer = await CustomerSdk.GetAsync(Id);
            if (customer != null)
            {
                _request = new CustomerRequest
                {
                    FirstName = customer.FirstName,
                    LastName = customer.LastName,
                    Email = customer.Email,
                    PhoneNumber = customer.PhoneNumber
                };
            }
            else
            {
                _error = "Klant niet gevonden.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Fout bij laden: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task HandleSubmit()
    {
        _saving = true;
        _error = null;

        try
        {
            var result = await CustomerSdk.UpdateAsync(Id, _request);
            if (result != null)
            {
                Navigation.NavigateTo("/customers");
            }
            else
            {
                _error = "Kon klant niet bijwerken.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Fout bij bijwerken: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }
}
