@page "/orders/{Id:guid}"

<PageTitle>Order Details - VivesRental</PageTitle>

<link href="css/pages/order-detail.css" rel="stylesheet" />

<h1>Order Details</h1>

@if (_loading)
{
    <p>Laden...</p>
}
else if (_error != null)
{
    <div class="alert alert-danger">@_error</div>
    <a href="/orders" class="btn btn-secondary">Terug naar overzicht</a>
}
else if (_order != null)
{
    <div class="order-header">
        <h2>Order #@_order.Id.ToString()[..8]...</h2>
        <div class="order-info">
            <div class="order-info-item">
                <label>Klant</label>
                <span>@_order.CustomerFirstName @_order.CustomerLastName</span>
            </div>
            <div class="order-info-item">
                <label>Email</label>
                <span>@_order.CustomerEmail</span>
            </div>
            <div class="order-info-item">
                <label>Telefoon</label>
                <span>@_order.CustomerPhoneNumber</span>
            </div>
            <div class="order-info-item">
                <label>Aangemaakt op</label>
                <span>@_order.CreatedAt.ToString("dd-MM-yyyy HH:mm")</span>
            </div>
            <div class="order-info-item">
                <label>Status</label>
                <span>
                    @if (_order.ReturnedAt.HasValue)
                    {
                        <span class="badge bg-success">Volledig teruggebracht</span>
                    }
                    else if (_orderLines.All(ol => ol.ReturnedAt.HasValue))
                    {
                        <span class="badge bg-success">Volledig teruggebracht</span>
                    }
                    else if (_orderLines.Any(ol => ol.ReturnedAt.HasValue))
                    {
                        <span class="badge bg-warning text-dark">Gedeeltelijk teruggebracht</span>
                    }
                    else
                    {
                        <span class="badge bg-primary">Actief</span>
                    }
                </span>
            </div>
            <div class="order-info-item">
                <label>Aantal items</label>
                <span>@_order.NumberOfOrderLines</span>
            </div>
        </div>
        <div class="order-actions">
            <a href="/orders" class="btn btn-secondary">Terug</a>
            @if (_orderLines.Any(ol => !ol.ReturnedAt.HasValue))
            {
                <button class="btn btn-success" @onclick="ReturnAll" disabled="@_processing">
                    @if (_processing) { <span>Bezig...</span> } else { <span>Alles Terugbrengen</span> }
                </button>
            }
        </div>
    </div>

    <div class="orderlines-section">
        <h3>Bestellijnen</h3>
        
        @if (_orderLines.Count == 0)
        {
            <p class="text-muted">Geen bestellijnen gevonden.</p>
        }
        else
        {
            @foreach (var line in _orderLines)
            {
                var isReturned = line.ReturnedAt.HasValue;
                var isOverdue = !isReturned && line.ExpiresAt < DateTime.Now;

                <div class="orderline-card @(isReturned ? "returned" : "")">
                    <div class="orderline-info">
                        <h5>@line.ProductName</h5>
                        <p class="orderline-dates">
                            <strong>Gehuurd:</strong> @line.RentedAt.ToString("dd-MM-yyyy HH:mm") |
                            <strong>Vervalt:</strong> @line.ExpiresAt.ToString("dd-MM-yyyy")
                            @if (isReturned)
                            {
                                <span> | <strong>Teruggebracht:</strong> @line.ReturnedAt!.Value.ToString("dd-MM-yyyy HH:mm")</span>
                            }
                        </p>
                        <p class="orderline-status @(isReturned ? "returned" : isOverdue ? "overdue" : "active")">
                            @if (isReturned)
                            {
                                <span>Teruggebracht</span>
                            }
                            else if (isOverdue)
                            {
                                <span>Te laat</span>
                            }
                            else
                            {
                                <span>Actief</span>
                            }
                        </p>
                    </div>
                    <div>
                        @if (!isReturned)
                        {
                            <button class="btn btn-sm btn-outline-success" @onclick="() => ReturnLine(line.Id)" disabled="@_processing">
                                Terugbrengen
                            </button>
                        }
                    </div>
                </div>
            }
        }
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    [Inject] private IOrderSdk OrderSdk { get; set; } = default!;
    [Inject] private IOrderLineSdk OrderLineSdk { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private OrderResult? _order;
    private IList<OrderLineResult> _orderLines = new List<OrderLineResult>();
    private bool _loading = true;
    private bool _processing;
    private string? _error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = null;

        try
        {
            _order = await OrderSdk.GetAsync(Id);
            if (_order == null)
            {
                _error = "Order niet gevonden.";
            }
            else
            {
                var allOrderLines = await OrderLineSdk.FindAsync();
                _orderLines = allOrderLines.Where(ol => ol.OrderId == Id).ToList();
            }
        }
        catch (Exception ex)
        {
            _error = $"Fout bij laden: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ReturnLine(Guid orderLineId)
    {
        _processing = true;
        try
        {
            var success = await OrderLineSdk.ReturnAsync(orderLineId, DateTime.Now);
            if (success)
            {
                await LoadData();
                StateHasChanged();
            }
            else
            {
                _error = "Kon item niet terugbrengen.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Fout: {ex.Message}";
        }
        finally
        {
            _processing = false;
        }
    }

    private async Task ReturnAll()
    {
        _processing = true;
        try
        {
            var success = await OrderSdk.ReturnAsync(Id, DateTime.Now);
            if (success)
            {
                await LoadData();
                StateHasChanged();
            }
            else
            {
                _error = "Kon order niet terugbrengen.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Fout: {ex.Message}";
        }
        finally
        {
            _processing = false;
        }
    }
}
