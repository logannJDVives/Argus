@page "/"
@page "/login"

<PageTitle>Inloggen - VivesRental</PageTitle>

<link href="css/pages/login.css" rel="stylesheet" />

<div class="login-container">
    <div class="login-card">
        <h2>VivesRental</h2>
        <p class="subtitle">Log in om door te gaan</p>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger">@_error</div>
        }

        @if (!string.IsNullOrEmpty(_success))
        {
            <div class="alert alert-success">@_success</div>
        }

        @if (_loading)
        {
            <div class="text-center py-4">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2">Bezig met inloggen...</p>
            </div>
        }
        else
        {
            <EditForm Model="@_loginModel" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />
                
                <div class="form-group">
                    <label>E-mail</label>
                    <InputText class="form-control" @bind-Value="_loginModel.Email" placeholder="Uw e-mailadres" />
                </div>
                
                <div class="form-group">
                    <label>Wachtwoord</label>
                    <InputText type="password" class="form-control" @bind-Value="_loginModel.Password" placeholder="Uw wachtwoord" />
                </div>
                
                <button type="submit" class="btn btn-primary w-100">
                    Inloggen
                </button>
            </EditForm>

            <div class="register-link">
                <p>Nog geen account? <a href="/register">Registreer hier</a></p>
            </div>
        }
    </div>
</div>

@code {
    [Inject] private IAuthSdk AuthSdk { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private LoginModel _loginModel = new();
    private string? _error;
    private string? _success;
    private bool _loading;

    protected override void OnInitialized()
    {
        // Check voor success message van registratie
        var uri = new Uri(Navigation.Uri);
        if (uri.Query.Contains("registered=true"))
        {
            _success = "Registratie succesvol! U kunt nu inloggen.";
        }
    }

    private async Task HandleLogin()
    {
        _error = null;
        _success = null;
        _loading = true;
        StateHasChanged();

        try
        {
            if (string.IsNullOrWhiteSpace(_loginModel.Email) || string.IsNullOrWhiteSpace(_loginModel.Password))
            {
                _error = "Vul uw e-mailadres en wachtwoord in.";
                _loading = false;
                return;
            }

            var response = await AuthSdk.LoginAsync(_loginModel.Email, _loginModel.Password);

            if (response != null)
            {
                await Task.Delay(100);
                Navigation.NavigateTo("/dashboard", forceLoad: true);
            }
            else
            {
                _error = "Ongeldige inloggegevens. Probeer opnieuw.";
                _loading = false;
            }
        }
        catch (Exception ex)
        {
            _error = $"Er is een fout opgetreden: {ex.Message}";
            _loading = false;
        }
    }

    private class LoginModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
