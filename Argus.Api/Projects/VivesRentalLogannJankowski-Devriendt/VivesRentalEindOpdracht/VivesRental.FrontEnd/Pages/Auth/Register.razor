@page "/register"

<PageTitle>Registreren - VivesRental</PageTitle>

<link href="css/pages/login.css" rel="stylesheet" />

<div class="login-container">
    <div class="login-card">
        <h2>Registreren</h2>
        <p class="subtitle">Maak een nieuw account aan</p>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger">@_error</div>
        }

        @if (_loading)
        {
            <div class="text-center py-4">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2">Bezig met registreren...</p>
            </div>
        }
        else
        {
            <EditForm Model="@_registerModel" OnValidSubmit="HandleRegister">
                <DataAnnotationsValidator />
                
                <div class="form-group">
                    <label>Voornaam *</label>
                    <InputText class="form-control" @bind-Value="_registerModel.FirstName" placeholder="Uw voornaam" />
                </div>
                
                <div class="form-group">
                    <label>Achternaam *</label>
                    <InputText class="form-control" @bind-Value="_registerModel.LastName" placeholder="Uw achternaam" />
                </div>
                
                <div class="form-group">
                    <label>E-mailadres *</label>
                    <InputText class="form-control" @bind-Value="_registerModel.Email" placeholder="email@voorbeeld.be" />
                </div>
                
                <div class="form-group">
                    <label>Telefoonnummer</label>
                    <InputText class="form-control" @bind-Value="_registerModel.PhoneNumber" placeholder="+32 471 12 34 56" />
                </div>
                
                <div class="form-group">
                    <label>Wachtwoord * (minimaal 6 tekens)</label>
                    <InputText type="password" class="form-control" @bind-Value="_registerModel.Password" placeholder="Kies een wachtwoord" />
                </div>
                
                <div class="form-group">
                    <label>Wachtwoord bevestigen *</label>
                    <InputText type="password" class="form-control" @bind-Value="_registerModel.ConfirmPassword" placeholder="Herhaal uw wachtwoord" />
                </div>
                
                <button type="submit" class="btn btn-primary w-100">
                    Registreren
                </button>
            </EditForm>

            <div class="register-link">
                <p>Heeft u al een account? <a href="/login">Log hier in</a></p>
            </div>
        }
    </div>
</div>

@code {
    [Inject] private IAuthSdk AuthSdk { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private RegisterModel _registerModel = new();
    private string? _error;
    private bool _loading;

    private async Task HandleRegister()
    {
        _error = null;
        _loading = true;
        StateHasChanged();

        try
        {
            // Validatie
            if (string.IsNullOrWhiteSpace(_registerModel.FirstName) ||
                string.IsNullOrWhiteSpace(_registerModel.LastName) ||
                string.IsNullOrWhiteSpace(_registerModel.Email) ||
                string.IsNullOrWhiteSpace(_registerModel.Password))
            {
                _error = "Vul alle verplichte velden in.";
                _loading = false;
                return;
            }

            if (_registerModel.Password.Length < 6)
            {
                _error = "Wachtwoord moet minimaal 6 tekens bevatten.";
                _loading = false;
                return;
            }

            if (_registerModel.Password != _registerModel.ConfirmPassword)
            {
                _error = "Wachtwoorden komen niet overeen.";
                _loading = false;
                return;
            }

            var request = new VivesRental.Sdk.Models.RegisterRequest
            {
                Email = _registerModel.Email,
                Password = _registerModel.Password,
                FirstName = _registerModel.FirstName,
                LastName = _registerModel.LastName,
                PhoneNumber = _registerModel.PhoneNumber ?? ""
            };

            var response = await AuthSdk.RegisterAsync(request);

            if (response != null && response.Success)
            {
                // Redirect naar login met success message
                Navigation.NavigateTo("/login?registered=true");
            }
            else
            {
                _error = response?.Message ?? "Registratie mislukt. Probeer opnieuw.";
                _loading = false;
            }
        }
        catch (Exception ex)
        {
            _error = $"Er is een fout opgetreden: {ex.Message}";
            _loading = false;
        }
    }

    private class RegisterModel
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Email { get; set; } = "";
        public string PhoneNumber { get; set; } = "";
        public string Password { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}
