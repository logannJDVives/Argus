@page "/dashboard"

<PageTitle>VivesRental - Dashboard</PageTitle>

<link href="css/pages/home.css" rel="stylesheet" />

<div class="dashboard">
    <div class="dashboard-header">
        <h1>Dashboard</h1>
        <p class="subtitle">
            @if (AuthSdk.IsAdmin())
            {
                <span>Verhuur Management Systeem - Beheerder</span>
            }
            else
            {
                <span>Welkom bij VivesRental</span>
            }
        </p>
    </div>

    <!-- Quick Action: Order ID invoer voor retour - voor iedereen -->
    <div class="quick-action">
        <h4>Materiaal Terugbrengen</h4>
        <div class="order-lookup">
            <input type="text" class="form-control" placeholder="Voer Order ID in..." @bind="_orderId" @onkeypress="HandleKeyPress" />
            <button class="btn btn-success" @onclick="NavigateToOrder" disabled="@string.IsNullOrWhiteSpace(_orderId)">
                Zoeken
            </button>
        </div>
        @if (_orderError != null)
        {
            <div class="alert alert-danger mt-2">@_orderError</div>
        }
    </div>

    <div class="dashboard-grid">
        @if (AuthSdk.IsAdmin())
        {
            <!-- Admin dashboard cards -->
            <a href="/customers" class="dashboard-card">
                <div class="card-icon">👥</div>
                <h3>Klantenbeheer</h3>
                <p>Beheer klanten en hun gegevens</p>
            </a>

            <a href="/articles" class="dashboard-card">
                <div class="card-icon">📦</div>
                <h3>Producten & Artikelen</h3>
                <p>Beheer producten en fysieke verhuurbare items</p>
            </a>

            <a href="/orders" class="dashboard-card dashboard-card-primary">
                <div class="card-icon">🛒</div>
                <h3>Verhuur</h3>
                <p>Beheer verhuringen en bestellingen</p>
            </a>

            <a href="/reservations" class="dashboard-card">
                <div class="card-icon">📅</div>
                <h3>Reserveringen</h3>
                <p>Beheer artikelreserveringen</p>
            </a>
        }
        else
        {
            <!-- Klant dashboard cards -->
            <a href="/reservations" class="dashboard-card dashboard-card-primary">
                <div class="card-icon">📅</div>
                <h3>Mijn Reserveringen</h3>
                <p>Bekijk en maak reserveringen</p>
            </a>

            <a href="/catalog" class="dashboard-card">
                <div class="card-icon">📦</div>
                <h3>Catalogus</h3>
                <p>Bekijk beschikbare producten</p>
            </a>
        }
    </div>
</div>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private IAuthSdk AuthSdk { get; set; } = default!;

    private string? _orderId;
    private string? _orderError;

    private void HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_orderId))
        {
            NavigateToOrder();
        }
    }

    private void NavigateToOrder()
    {
        _orderError = null;

        if (Guid.TryParse(_orderId?.Trim(), out var guid))
        {
            Navigation.NavigateTo($"/orders/{guid}");
        }
        else
        {
            _orderError = "Ongeldig Order ID formaat. Voer een geldig GUID in.";
        }
    }
}
