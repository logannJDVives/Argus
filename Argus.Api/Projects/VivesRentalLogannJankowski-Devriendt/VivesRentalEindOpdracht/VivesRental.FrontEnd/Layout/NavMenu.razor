<nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">
            <strong>VivesRental</strong>
        </a>
        <button class="navbar-toggler" type="button" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
        
        <div class="@NavMenuCssClass navbar-collapse">
            @if (AuthSdk.IsAuthenticated())
            {
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <NavLink class="nav-link" href="dashboard" Match="NavLinkMatch.All">
                            Dashboard
                        </NavLink>
                    </li>
                    
                    @if (AuthSdk.IsAdmin())
                    {
                        <!-- Admin-only menu items -->
                        <li class="nav-item">
                            <NavLink class="nav-link" href="customers">
                                Klanten
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="articles">
                                Producten & Artikelen
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="orders">
                                Bestellingen
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="reservations">
                                Reserveringen
                            </NavLink>
                        </li>
                    }
                    else
                    {
                        <!-- Klant menu items -->
                        <li class="nav-item">
                            <NavLink class="nav-link" href="catalog">
                                Catalogus
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="reservations">
                                Mijn Reserveringen
                            </NavLink>
                        </li>
                    }
                </ul>
                
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <span class="nav-link user-info">
                            @AuthSdk.GetUserEmail()
                            @if (AuthSdk.IsAdmin())
                            {
                                <span class="badge bg-warning text-dark ms-1">Admin</span>
                            }
                            else
                            {
                                <span class="badge bg-info ms-1">Klant</span>
                            }
                        </span>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link btn btn-link" @onclick="Logout">
                            Uitloggen
                        </button>
                    </li>
                </ul>
            }
        </div>
    </div>
</nav>

@code {
    [Inject] private IAuthSdk AuthSdk { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void Logout()
    {
        AuthSdk.Logout();
        Navigation.NavigateTo("/", forceLoad: true);
    }
}
