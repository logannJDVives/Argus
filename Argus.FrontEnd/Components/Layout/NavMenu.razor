@inject AuthStateService Auth
@inject NavigationManager Nav

<header class="topnav">
    <div class="topnav-inner">

        <a class="topnav-brand" href="">
            <svg class="brand-logo" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/>
                <circle cx="12" cy="12" r="3.5" fill="currentColor"/>
                <line x1="2.5" y1="12" x2="8"   y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <line x1="16"  y1="12" x2="21.5" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <line x1="12"  y1="2.5" x2="12"  y2="8"  stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <line x1="12"  y1="16"  x2="12"  y2="21.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            Argus
        </a>

        <nav class="topnav-links" aria-label="Main navigation">
            @if (Auth.IsAuthenticated)
            {
                <NavLink class="nav-lnk" href="projects">Projects</NavLink>
                <NavLink class="nav-lnk" href="upload">Upload</NavLink>
            }
        </nav>

        <div class="topnav-actions">
            @if (Auth.IsAuthenticated)
            {
                <div class="user-badge">
                    <span class="user-avatar">@(Auth.Email is { Length: > 0 } e ? char.ToUpper(e[0]).ToString() : "U")</span>
                    <span class="user-email">@Auth.Email</span>
                </div>
                <button class="btn-signout" @onclick="Logout">Sign out</button>
            }
            else
            {
                <NavLink class="btn-ghost" href="login">Sign in</NavLink>
                <NavLink class="btn-accent" href="register">Register</NavLink>
            }
        </div>

        <button class="mobile-toggle" @onclick="ToggleMobileMenu" aria-label="Toggle navigation">
            <span class="toggle-bar"></span>
            <span class="toggle-bar"></span>
            <span class="toggle-bar"></span>
        </button>

    </div>

    @if (_mobileOpen)
    {
        <div class="mobile-menu">
            @if (Auth.IsAuthenticated)
            {
                <NavLink class="mobile-lnk" href="projects" @onclick="CloseMobile">Projects</NavLink>
                <NavLink class="mobile-lnk" href="upload" @onclick="CloseMobile">Upload</NavLink>
                <button class="mobile-lnk mobile-signout" @onclick="Logout">Sign out (@Auth.Email)</button>
            }
            else
            {
                <NavLink class="mobile-lnk" href="login" @onclick="CloseMobile">Sign in</NavLink>
                <NavLink class="mobile-lnk" href="register" @onclick="CloseMobile">Register</NavLink>
            }
        </div>
    }
</header>

@code {
    private bool _mobileOpen;

    private void ToggleMobileMenu() => _mobileOpen = !_mobileOpen;
    private void CloseMobile()      => _mobileOpen = false;

    private void Logout()
    {
        _mobileOpen = false;
        Auth.Logout();
        Nav.NavigateTo("/login");
    }
}
