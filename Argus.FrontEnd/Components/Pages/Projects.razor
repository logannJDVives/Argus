@page "/projects"
@inject ArgusApiClient Api
@inject AuthStateService Auth
@inject NavigationManager Nav

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Projects</h2>
    <a href="upload" class="btn btn-primary">+ Upload Project</a>
</div>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2 text-muted">Loading projects…</p>
    </div>
}
else if (_errorMessage is not null)
{
    <div class="alert alert-danger">@_errorMessage</div>
}
else if (_projects.Count == 0)
{
    <div class="alert alert-info">
        You haven't uploaded any projects to analyze, <a href="upload">upload your first project!</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Created</th>
                    <th>Last scan</th>
                    <th class="text-center">Scans</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var project in _projects)
                {
                    <tr>
                        <td class="fw-semibold">
                            @if (_editingProjectId == project.Id)
                            {
                                <input class="form-control form-control-sm d-inline-block"
                                       style="max-width: 220px"
                                       @bind="_editName"
                                       @bind:event="oninput" />
                            }
                            else
                            {
                                @project.Name
                            }
                        </td>
                        <td class="text-muted small">@project.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-muted small">
                            @(project.LastScanDate.HasValue
                                ? project.LastScanDate.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                : "—")
                        </td>
                        <td class="text-center">@project.ScanRunCount</td>
                        <td class="text-end">
                            @if (_editingProjectId == project.Id)
                            {
                                <button class="btn btn-sm btn-primary me-1"
                                        @onclick="() => HandleRenameAsync(project)"
                                        disabled="@(string.IsNullOrWhiteSpace(_editName))">
                                    Save
                                </button>
                                <button class="btn btn-sm btn-outline-secondary"
                                        @onclick="CancelRename">
                                    Cancel
                                </button>
                            }
                            else if (_confirmDeleteId == project.Id)
                            {
                                <span class="me-2 text-danger small fw-semibold">Delete '@project.Name'?</span>
                                <button class="btn btn-sm btn-danger me-1"
                                        @onclick="() => HandleDeleteAsync(project)">
                                    Yes, delete
                                </button>
                                <button class="btn btn-sm btn-outline-secondary"
                                        @onclick="() => _confirmDeleteId = null">
                                    Cancel
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-success me-2"
                                        @onclick="() => StartScanAsync(project)"
                                        disabled="@(_scanningProjectId == project.Id)">
                                    @if (_scanningProjectId == project.Id)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                        <span>Scanning…</span>
                                    }
                                    else
                                    {
                                        <span>▶ Scan</span>
                                    }
                                </button>
                                @if (project.ScanRunCount > 0)
                                {
                                    <a href="projects/@project.Id/scans" class="btn btn-sm btn-outline-secondary me-2">History</a>
                                }
                                <button class="btn btn-sm btn-outline-primary me-2"
                                        @onclick="() => StartRename(project)">
                                    ✏ Rename
                                </button>
                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => { _confirmDeleteId = project.Id; _editingProjectId = null; }">
                                    🗑 Delete
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (_scanError is not null)
{
    <div class="alert alert-danger mt-3">@_scanError</div>
}

@if (_actionError is not null)
{
    <div class="alert alert-danger mt-3">@_actionError</div>
}

@code {
    private List<ProjectDto> _projects = [];
    private bool _loading = true;
    private string? _errorMessage;
    private string? _scanError;
    private string? _actionError;
    private Guid? _scanningProjectId;
    private Guid? _editingProjectId;
    private string _editName = string.Empty;
    private Guid? _confirmDeleteId;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsAuthenticated)
        {
            Nav.NavigateTo("/login");
            return;
        }

        try
        {
            _projects = await Api.GetProjectsAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load projects: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void StartRename(ProjectDto project)
    {
        _editingProjectId = project.Id;
        _editName = project.Name;
        _confirmDeleteId = null;
        _actionError = null;
    }

    private void CancelRename()
    {
        _editingProjectId = null;
        _editName = string.Empty;
    }

    private async Task HandleRenameAsync(ProjectDto project)
    {
        _actionError = null;
        try
        {
            var updated = await Api.UpdateProjectAsync(project.Id, new UpdateProjectDto { Name = _editName.Trim() });
            var index = _projects.IndexOf(project);
            if (index >= 0)
                _projects[index] = updated;
            _editingProjectId = null;
            _editName = string.Empty;
        }
        catch (Exception ex)
        {
            _actionError = $"Rename failed: {ex.Message}";
        }
    }

    private async Task HandleDeleteAsync(ProjectDto project)
    {
        _actionError = null;
        try
        {
            await Api.DeleteProjectAsync(project.Id);
            _projects.Remove(project);
            _confirmDeleteId = null;
        }
        catch (Exception ex)
        {
            _actionError = $"Delete failed: {ex.Message}";
        }
    }

    private async Task StartScanAsync(ProjectDto project)
    {
        _scanningProjectId = project.Id;
        _scanError = null;

        try
        {
            var scan = await Api.StartScanAsync(project.Id);
            Nav.NavigateTo($"projects/{project.Id}/scans/{scan.Id}");
        }
        catch (Exception ex)
        {
            _scanError = $"Scan failed for '{project.Name}': {ex.Message}";
        }
        finally
        {
            _scanningProjectId = null;
        }
    }
}
