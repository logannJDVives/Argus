@page "/projects/{ProjectId:guid}/scans"
@inject ArgusApiClient Api
@inject NavigationManager Nav

<a href="projects" class="back-link">← Projects</a>

<div class="page-header mb-0">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="mb-1">Scan History</h2>
            <p class="text-muted mb-0">All scan runs for this project.</p>
        </div>
        <button class="btn btn-primary" @onclick="StartScanAsync" disabled="@_scanning">
            @if (_scanning)
            {
                <span class="spinner-border spinner-border-sm" role="status"></span>
                <span>Scanning…</span>
            }
            else
            {
                <span>▶ New scan</span>
            }
        </button>
    </div>
</div>

@if (_errorMessage is not null)
{
    <div class="alert alert-danger mt-4">@_errorMessage</div>
}

@if (_loading)
{
    <div class="state-loading">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Loading scans…</p>
    </div>
}
else if (_scans.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon">🔍</div>
        <h3 class="empty-state-title">No scans yet</h3>
        <p class="empty-state-desc">Start a new scan to detect secrets and generate an SBOM for this project.</p>
        <button class="btn btn-primary px-4" @onclick="StartScanAsync" disabled="@_scanning">
            @if (_scanning)
            {
                <span class="spinner-border spinner-border-sm" role="status"></span>
            }
            ▶ Start first scan
        </button>
    </div>
}
else
{
    <div class="scan-list mt-4">
        @foreach (var scan in _scans)
        {
            <div class="scan-row">
                <div class="scan-row-info">
                    <div class="scan-row-date">@scan.CreatedAt.ToLocalTime().ToString("dd MMM yyyy · HH:mm")</div>
                    <div class="scan-row-meta">
                        <span class="badge @StatusBadgeClass(scan.Status)">@scan.Status</span>
                        @if (scan.Duration.HasValue)
                        {
                            <span>@($"{scan.Duration.Value.TotalSeconds:F1}s")</span>
                        }
                    </div>
                </div>
                <div class="scan-row-stats">
                    <div class="scan-stat">
                        <div class="scan-stat-value @(scan.SecretCount > 0 ? "danger" : "success")">@scan.SecretCount</div>
                        <div class="scan-stat-label">Secrets</div>
                    </div>
                    <div class="scan-stat">
                        <div class="scan-stat-value">@(scan.FilesScanned ?? 0)</div>
                        <div class="scan-stat-label">Files</div>
                    </div>
                </div>
                <div class="scan-row-actions">
                    <a href="projects/@ProjectId/scans/@scan.Id" class="btn btn-sm btn-outline-secondary">View results</a>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public Guid ProjectId { get; set; }

    private List<ScanRunDto> _scans = [];
    private bool    _loading = true;
    private bool    _scanning;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _scans = await Api.GetScansAsync(ProjectId);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load scans: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task StartScanAsync()
    {
        _scanning     = true;
        _errorMessage = null;
        try
        {
            var scan = await Api.StartScanAsync(ProjectId);
            Nav.NavigateTo($"projects/{ProjectId}/scans/{scan.Id}");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Scan failed: {ex.Message}";
        }
        finally
        {
            _scanning = false;
        }
    }

    private static string StatusBadgeClass(string status) => status switch
    {
        "Completed"  => "badge-success",
        "InProgress" => "badge-warning",
        "Failed"     => "badge-danger",
        _            => "badge-neutral"
    };
}
