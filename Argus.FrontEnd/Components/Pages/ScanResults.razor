@page "/projects/{ProjectId:guid}/scans/{ScanId:guid}"
@using Argus.Dto.Components
@inject ArgusApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<a href="projects/@ProjectId/scans" class="back-link">← Scan history</a>

@if (_loading)
{
    <div class="state-loading">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Loading results…</p>
    </div>
}
else if (_errorMessage is not null)
{
    <div class="alert alert-danger">@_errorMessage</div>
}
else if (_scan is not null)
{
    <div class="page-header mb-0">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="mb-1">Scan Results</h2>
                <p class="mb-0 text-muted">@_scan.CreatedAt.ToLocalTime().ToString("dd MMM yyyy · HH:mm")</p>
            </div>
            <span class="badge @StatusBadgeClass(_scan.Status)">@_scan.Status</span>
        </div>
    </div>

    <div class="stat-grid mt-4">
        <div class="stat-card">
            <div class="stat-card-label">Secrets found</div>
            <div class="stat-card-value @(_scan.SecretCount > 0 ? "danger" : "success")">@_scan.SecretCount</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-label">Files scanned</div>
            <div class="stat-card-value">@(_scan.FilesScanned ?? 0)</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-label">Duration</div>
            <div class="stat-card-value">@(_scan.Duration.HasValue ? $"{_scan.Duration.Value.TotalSeconds:F1}s" : "—")</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-label">Components</div>
            <div class="stat-card-value">@_scan.ComponentCount</div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_scan.ErrorMessage))
    {
        <div class="alert alert-warning mb-4">@_scan.ErrorMessage</div>
    }

    <div class="tab-bar">
        <button class="tab-btn @(_activeTab == "secrets" ? "active" : "")"
                @onclick='() => _activeTab = "secrets"'>
            Secrets
            @if (_scan.SecretCount > 0)
            {
                <span class="tab-count danger">@_scan.SecretCount</span>
            }
        </button>
        <button class="tab-btn @(_activeTab == "sbom" ? "active" : "")"
                @onclick="SwitchToSbomAsync">
            SBOM
            @if (_scan.ComponentCount > 0)
            {
                <span class="tab-count">@_scan.ComponentCount</span>
            }
        </button>
    </div>

    @if (_activeTab == "secrets")
    {
        @if (_scan.SecretCount == 0)
        {
            <div class="alert alert-success">No secrets detected in this scan.</div>
        }
        else if (_secrets is not null)
        {
            <div class="d-flex align-items-center gap-2 mb-3">
                <select class="form-select form-select-sm"
                        style="max-width:180px"
                        @bind="_severityFilter"
                        @bind:after="ResetAndLoadSecretsAsync">
                    <option value="">All severities</option>
                    <option value="Critical">Critical</option>
                    <option value="High">High</option>
                    <option value="Medium">Medium</option>
                    <option value="Low">Low</option>
                </select>
                <span class="text-muted small">@_secrets.TotalCount result@(_secrets.TotalCount == 1 ? "" : "s")</span>
            </div>

            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Rule</th>
                            <th>Severity</th>
                            <th>File</th>
                            <th style="text-align:center">Line</th>
                            <th>Value (masked)</th>
                            <th style="text-align:center">False positive</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var secret in _secrets.Items)
                        {
                            <tr style="@(secret.IsFalsePositive ? "opacity:.45;text-decoration:line-through" : "")">
                                <td><code class="small">@secret.RuleId</code></td>
                                <td><span class="badge @SeverityBadgeClass(secret.Severity)">@secret.Severity</span></td>
                                <td class="small text-break" style="max-width:220px">@secret.FilePath</td>
                                <td class="small text-muted" style="text-align:center">@secret.LineNumber</td>
                                <td><code class="small">@secret.MaskedValue</code></td>
                                <td style="text-align:center">
                                    <input type="checkbox"
                                           class="form-check-input"
                                           checked="@secret.IsFalsePositive"
                                           @onchange="e => ToggleFalsePositiveAsync(secret, (bool)e.Value!)" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (_secrets.TotalPages > 1)
            {
                <div class="pagination-bar">
                    <button class="page-btn" @onclick="() => LoadSecretsAsync(_currentSecretsPage - 1)" disabled="@(!_secrets.HasPreviousPage)">‹</button>
                    @for (int p = 1; p <= _secrets.TotalPages; p++)
                    {
                        var pg = p;
                        <button class="page-btn @(pg == _currentSecretsPage ? "active" : "")" @onclick="() => LoadSecretsAsync(pg)">@pg</button>
                    }
                    <button class="page-btn" @onclick="() => LoadSecretsAsync(_currentSecretsPage + 1)" disabled="@(!_secrets.HasNextPage)">›</button>
                </div>
            }
        }
    }

    @if (_activeTab == "sbom")
    {
        @if (_sbomLoading)
        {
            <div class="state-loading" style="padding:3rem 0">
                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                <p class="mt-2 text-muted small">Loading SBOM…</p>
            </div>
        }
        else if (_scan.ComponentCount == 0)
        {
            <div class="alert alert-info">No components found in this scan.</div>
        }
        else if (_components is not null)
        {
            <div class="d-flex align-items-center gap-2 mb-3">
                <input class="form-control form-control-sm"
                       style="max-width:280px"
                       placeholder="Search by name or package URL…"
                       @bind="_componentSearch"
                       @bind:event="oninput"
                       @bind:after="ResetAndLoadComponentsAsync" />
                <span class="text-muted small ms-auto">@_components.TotalCount component@(_components.TotalCount == 1 ? "" : "s")</span>
                <button class="btn btn-sm btn-outline-secondary"
                        @onclick="DownloadSbomAsync"
                        disabled="@_sbomDownloading">
                    @if (_sbomDownloading)
                    {
                        <span class="spinner-border spinner-border-sm" role="status"></span>
                    }
                    Download CycloneDX
                </button>
            </div>

            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Version</th>
                            <th>License</th>
                            <th style="text-align:center">Type</th>
                            <th style="text-align:center">CVEs</th>
                            <th>Package URL</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in _components.Items)
                        {
                            <tr>
                                <td class="fw-semibold small">
                                    @if (!string.IsNullOrEmpty(c.Homepage))
                                    {
                                        <a href="@c.Homepage" target="_blank" rel="noopener noreferrer">@c.Name</a>
                                    }
                                    else
                                    {
                                        @c.Name
                                    }
                                </td>
                                <td class="small text-muted">@c.Version</td>
                                <td class="small">
                                    @if (string.IsNullOrEmpty(c.License))
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-neutral">@c.License</span>
                                    }
                                </td>
                                <td style="text-align:center">
                                    @if (c.IsTransitive)
                                    {
                                        <span class="badge badge-neutral">Transitive</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-info">Direct</span>
                                    }
                                </td>
                                <td style="text-align:center">
                                    @if (c.HasKnownVulnerabilities)
                                    {
                                        <span class="badge badge-danger">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-success">None</span>
                                    }
                                </td>
                                <td><code class="small text-break">@c.PackageUrl</code></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (_components.TotalPages > 1)
            {
                <div class="pagination-bar">
                    <button class="page-btn" @onclick="() => LoadComponentsAsync(_currentComponentsPage - 1)" disabled="@(!_components.HasPreviousPage)">‹</button>
                    @for (int p = 1; p <= _components.TotalPages; p++)
                    {
                        var pg = p;
                        <button class="page-btn @(pg == _currentComponentsPage ? "active" : "")" @onclick="() => LoadComponentsAsync(pg)">@pg</button>
                    }
                    <button class="page-btn" @onclick="() => LoadComponentsAsync(_currentComponentsPage + 1)" disabled="@(!_components.HasNextPage)">›</button>
                </div>
            }
        }
    }
}

@code {
    [Parameter] public Guid ProjectId { get; set; }
    [Parameter] public Guid ScanId   { get; set; }

    private ScanRunDto?             _scan;
    private PaginatedSecretsDto?    _secrets;
    private PaginatedComponentsDto? _components;

    private bool    _loading      = true;
    private bool    _sbomLoading  = false;
    private string? _errorMessage;
    private string  _activeTab    = "secrets";

    private string _severityFilter      = string.Empty;
    private int    _currentSecretsPage  = 1;

    private string _componentSearch       = string.Empty;
    private int    _currentComponentsPage = 1;
    private bool   _sbomDownloading       = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _scan = await Api.GetScanAsync(ProjectId, ScanId);
            if (_scan is not null && _scan.SecretCount > 0)
                await LoadSecretsAsync(1);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load scan: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ResetAndLoadSecretsAsync()
    {
        _currentSecretsPage = 1;
        await LoadSecretsAsync(1);
    }

    private async Task LoadSecretsAsync(int page)
    {
        _currentSecretsPage = page;
        _secrets = await Api.GetSecretsAsync(ScanId, severity: _severityFilter, page: page);
        StateHasChanged();
    }

    private async Task ToggleFalsePositiveAsync(DetectedSecretDto secret, bool value)
    {
        secret.IsFalsePositive = value;
        await Api.ReviewSecretAsync(secret.Id, isReviewed: true, isFalsePositive: value);
    }

    private async Task SwitchToSbomAsync()
    {
        _activeTab = "sbom";
        if (_components is null)
            await LoadComponentsAsync(1);
    }

    private async Task ResetAndLoadComponentsAsync()
    {
        _currentComponentsPage = 1;
        await LoadComponentsAsync(1);
    }

    private async Task LoadComponentsAsync(int page)
    {
        _sbomLoading = true;
        StateHasChanged();
        try
        {
            _currentComponentsPage = page;
            _components = await Api.GetComponentsAsync(ScanId, search: _componentSearch, page: page);
        }
        finally
        {
            _sbomLoading = false;
            StateHasChanged();
        }
    }

    private async Task DownloadSbomAsync()
    {
        _sbomDownloading = true;
        try
        {
            var bytes    = await Api.DownloadSbomAsync(ScanId);
            var fileName = $"sbom-{ScanId:N}.cdx.json";
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, "application/json", bytes);
        }
        finally
        {
            _sbomDownloading = false;
        }
    }

    private static string StatusBadgeClass(string status) => status switch
    {
        "Completed"  => "badge badge-success",
        "InProgress" => "badge badge-warning",
        "Failed"     => "badge badge-danger",
        _            => "badge badge-neutral"
    };

    private static string SeverityBadgeClass(string severity) => severity switch
    {
        "Critical" => "badge sev-critical",
        "High"     => "badge sev-high",
        "Medium"   => "badge sev-medium",
        "Low"      => "badge sev-low",
        _          => "badge badge-neutral"
    };
}
