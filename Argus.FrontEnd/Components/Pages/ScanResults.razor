@page "/projects/{ProjectId:guid}/scans/{ScanId:guid}"
@using Argus.Dto.Components
@inject ArgusApiClient Api
@inject NavigationManager Nav

<a href="projects/@ProjectId/scans" class="btn btn-sm btn-outline-secondary mb-4">← Back to scan history</a>

@if (_loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2 text-muted">Loading results…</p>
    </div>
}
else if (_errorMessage is not null)
{
    <div class="alert alert-danger">@_errorMessage</div>
}
else if (_scan is not null)
{
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="mb-1">Scan Results</h2>
            <span class="text-muted small">@_scan.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
        </div>
        <span class="badge fs-6 @StatusBadgeClass(_scan.Status)">@_scan.Status</span>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card text-center h-100">
                <div class="card-body">
                    <div class="fs-2 fw-bold @(_scan.SecretCount > 0 ? "text-danger" : "text-success")">
                        @_scan.SecretCount
                    </div>
                    <div class="text-muted small">Secrets found</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center h-100">
                <div class="card-body">
                    <div class="fs-2 fw-bold">@(_scan.FilesScanned ?? 0)</div>
                    <div class="text-muted small">Files scanned</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center h-100">
                <div class="card-body">
                    <div class="fs-2 fw-bold">
                        @(_scan.Duration.HasValue ? $"{_scan.Duration.Value.TotalSeconds:F1}s" : "—")
                    </div>
                    <div class="text-muted small">Duration</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center h-100">
                <div class="card-body">
                    <div class="fs-2 fw-bold">@_scan.ComponentCount</div>
                    <div class="text-muted small">Components (SBOM)</div>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_scan.ErrorMessage))
    {
        <div class="alert alert-warning">
            <strong>Scan error:</strong> @_scan.ErrorMessage
        </div>
    }

    <!-- Tab navigation -->
    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <button class="nav-link @(_activeTab == "secrets" ? "active" : "")"
                    @onclick='() => _activeTab = "secrets"'>
                🔑 Secrets
                @if (_scan.SecretCount > 0)
                {
                    <span class="badge bg-danger ms-1">@_scan.SecretCount</span>
                }
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(_activeTab == "sbom" ? "active" : "")"
                    @onclick="SwitchToSbomAsync">
                📦 SBOM
                @if (_scan.ComponentCount > 0)
                {
                    <span class="badge bg-secondary ms-1">@_scan.ComponentCount</span>
                }
            </button>
        </li>
    </ul>

    <!-- Secrets tab -->
    @if (_activeTab == "secrets")
    {
        @if (_secrets is not null && _secrets.Items.Count > 0)
        {
            <div class="d-flex gap-2 mb-3">
                <select class="form-select form-select-sm w-auto"
                        @bind="_severityFilter"
                        @bind:after="ResetAndLoadSecretsAsync">
                    <option value="">All severities</option>
                    <option value="Critical">Critical</option>
                    <option value="High">High</option>
                    <option value="Medium">Medium</option>
                    <option value="Low">Low</option>
                </select>
            </div>

            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Rule</th>
                            <th>Severity</th>
                            <th>Confidence</th>
                            <th>File</th>
                            <th class="text-center">Line</th>
                            <th>Value (masked)</th>
                            <th class="text-center">False positive</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var secret in _secrets.Items)
                        {
                            <tr class="@(secret.IsFalsePositive ? "table-secondary text-decoration-line-through" : "")">
                                <td><code class="small">@secret.RuleId</code></td>
                                <td><span class="badge @SeverityBadgeClass(secret.Severity)">@secret.Severity</span></td>
                                <td class="small text-muted">@secret.Confidence</td>
                                <td class="small text-break" style="max-width:220px;">@secret.FilePath</td>
                                <td class="text-center small">@secret.LineNumber</td>
                                <td><code class="small">@secret.MaskedValue</code></td>
                                <td class="text-center">
                                    <input type="checkbox"
                                           class="form-check-input"
                                           checked="@secret.IsFalsePositive"
                                           @onchange="e => ToggleFalsePositiveAsync(secret, (bool)e.Value!)" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (_secrets.TotalPages > 1)
            {
                <nav class="mt-3">
                    <ul class="pagination pagination-sm justify-content-center">
                        <li class="page-item @(!_secrets.HasPreviousPage ? "disabled" : "")">
                            <button class="page-link" @onclick="() => LoadSecretsAsync(_currentSecretsPage - 1)">‹</button>
                        </li>
                        @for (int p = 1; p <= _secrets.TotalPages; p++)
                        {
                            var page = p;
                            <li class="page-item @(page == _currentSecretsPage ? "active" : "")">
                                <button class="page-link" @onclick="() => LoadSecretsAsync(page)">@(page)</button>
                            </li>
                        }
                        <li class="page-item @(!_secrets.HasNextPage ? "disabled" : "")">
                            <button class="page-link" @onclick="() => LoadSecretsAsync(_currentSecretsPage + 1)">›</button>
                        </li>
                    </ul>
                </nav>
            }
        }
        else if (_scan.SecretCount == 0)
        {
            <div class="alert alert-success">✅ No secrets detected in this scan.</div>
        }
    }

    <!-- SBOM tab -->
    @if (_activeTab == "sbom")
    {
        @if (_sbomLoading)
        {
            <div class="text-center py-4">
                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                <span class="ms-2 text-muted">Loading SBOM…</span>
            </div>
        }
        else if (_components is not null && _components.Items.Count > 0)
        {
            <div class="d-flex align-items-center gap-2 mb-3">
                <input class="form-control form-control-sm"
                       style="max-width:280px"
                       placeholder="Search by name or package URL…"
                       @bind="_componentSearch"
                       @bind:event="oninput"
                       @bind:after="ResetAndLoadComponentsAsync" />
                <span class="text-muted small">@_components.TotalCount component@(_components.TotalCount == 1 ? "" : "s")</span>
            </div>

            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Version</th>
                            <th>License</th>
                            <th class="text-center">Dependency</th>
                            <th class="text-center">Known CVEs</th>
                            <th>Package URL</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in _components.Items)
                        {
                            <tr>
                                <td class="fw-semibold small">
                                    @if (!string.IsNullOrEmpty(c.Homepage))
                                    {
                                        <a href="@c.Homepage" target="_blank" rel="noopener noreferrer">@c.Name</a>
                                    }
                                    else
                                    {
                                        @c.Name
                                    }
                                </td>
                                <td class="small text-muted">@c.Version</td>
                                <td class="small">
                                    @if (string.IsNullOrEmpty(c.License))
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark border">@c.License</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (c.IsTransitive)
                                    {
                                        <span class="badge bg-light text-dark border">Transitive</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary">Direct</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (c.HasKnownVulnerabilities)
                                    {
                                        <span class="badge bg-danger">⚠ Yes</span>
                                    }
                                    else
                                    {
                                        <span class="text-success small">✓</span>
                                    }
                                </td>
                                <td><code class="small text-break">@c.PackageUrl</code></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (_components.TotalPages > 1)
            {
                <nav class="mt-3">
                    <ul class="pagination pagination-sm justify-content-center">
                        <li class="page-item @(!_components.HasPreviousPage ? "disabled" : "")">
                            <button class="page-link" @onclick="() => LoadComponentsAsync(_currentComponentsPage - 1)">‹</button>
                        </li>
                        @for (int p = 1; p <= _components.TotalPages; p++)
                        {
                            var page = p;
                            <li class="page-item @(page == _currentComponentsPage ? "active" : "")">
                                <button class="page-link" @onclick="() => LoadComponentsAsync(page)">@(page)</button>
                            </li>
                        }
                        <li class="page-item @(!_components.HasNextPage ? "disabled" : "")">
                            <button class="page-link" @onclick="() => LoadComponentsAsync(_currentComponentsPage + 1)">›</button>
                        </li>
                    </ul>
                </nav>
            }
        }
        else if (_scan.ComponentCount == 0)
        {
            <div class="alert alert-info">📦 No components found in this scan.</div>
        }
    }
}

@code {
    [Parameter] public Guid ProjectId { get; set; }
    [Parameter] public Guid ScanId   { get; set; }

    private ScanRunDto?             _scan;
    private PaginatedSecretsDto?    _secrets;
    private PaginatedComponentsDto? _components;

    private bool    _loading     = true;
    private bool    _sbomLoading = false;
    private string? _errorMessage;
    private string  _activeTab   = "secrets";

    // Secrets state
    private string _severityFilter     = string.Empty;
    private int    _currentSecretsPage = 1;

    // SBOM state
    private string _componentSearch       = string.Empty;
    private int    _currentComponentsPage = 1;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _scan = await Api.GetScanAsync(ProjectId, ScanId);
            if (_scan is not null && _scan.SecretCount > 0)
                await LoadSecretsAsync(1);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load scan: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    // ── Secrets ─────────────────────────────────────────────────────────────

    private async Task ResetAndLoadSecretsAsync()
    {
        _currentSecretsPage = 1;
        await LoadSecretsAsync(1);
    }

    private async Task LoadSecretsAsync(int page)
    {
        _currentSecretsPage = page;
        _secrets = await Api.GetSecretsAsync(ScanId, severity: _severityFilter, page: page);
        StateHasChanged();
    }

    private async Task ToggleFalsePositiveAsync(DetectedSecretDto secret, bool value)
    {
        secret.IsFalsePositive = value;
        await Api.ReviewSecretAsync(secret.Id, isReviewed: true, isFalsePositive: value);
    }

    // ── SBOM ────────────────────────────────────────────────────────────────

    private async Task SwitchToSbomAsync()
    {
        _activeTab = "sbom";
        if (_components is null)
            await LoadComponentsAsync(1);
    }

    private async Task ResetAndLoadComponentsAsync()
    {
        _currentComponentsPage = 1;
        await LoadComponentsAsync(1);
    }

    private async Task LoadComponentsAsync(int page)
    {
        _sbomLoading = true;
        StateHasChanged();
        try
        {
            _currentComponentsPage = page;
            _components = await Api.GetComponentsAsync(ScanId, search: _componentSearch, page: page);
        }
        finally
        {
            _sbomLoading = false;
            StateHasChanged();
        }
    }

    // ── Helpers ─────────────────────────────────────────────────────────────

    private static string StatusBadgeClass(string status) => status switch
    {
        "Completed"  => "bg-success",
        "InProgress" => "bg-warning text-dark",
        "Failed"     => "bg-danger",
        _            => "bg-secondary"
    };

    private static string SeverityBadgeClass(string severity) => severity switch
    {
        "Critical" => "bg-danger",
        "High"     => "bg-warning text-dark",
        "Medium"   => "bg-info text-dark",
        "Low"      => "bg-secondary",
        _          => "bg-light text-dark"
    };
}
