@page "/upload"
@using Argus.Sdk
@using System.IO
@inject ArgusApiClient ApiClient
@inject NavigationManager Nav

<div class="page-header mb-5">
    <h2 class="mb-1">Upload project</h2>
    <p class="text-muted">Upload a ZIP archive to scan for secrets and generate an SBOM.</p>
</div>

<div class="upload-card">
    @if (isLoading)
    {
        <div class="upload-loading">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3 mb-1 fw-medium">Uploading project…</p>
            <p class="text-muted small">This may take a moment</p>
        </div>
    }
    else
    {
        <form @onsubmit="HandleUploadProject">

            <div class="mb-4">
                <label class="form-label" for="projectName">Project name</label>
                <input type="text"
                       id="projectName"
                       class="form-control"
                       @bind="projectName"
                       placeholder="e.g. MyWebApp"
                       maxlength="100"
                       disabled="@isLoading" />
            </div>

            <div class="mb-4">
                <label class="form-label" for="zipFile">
                    ZIP file <span class="text-muted fw-normal">(max 100 MB)</span>
                </label>
                <div class="upload-dropzone @(fileBytes != null ? "upload-dropzone--selected" : "")">
                    <InputFile id="zipFile"
                               OnChange="HandleFileSelected"
                               accept=".zip"
                               disabled="@isLoading"
                               class="upload-file-input" />
                    @if (fileBytes != null)
                    {
                        <div class="upload-file-info">
                            <span class="upload-file-icon">📦</span>
                            <div>
                                <div class="fw-medium small">@selectedFileName</div>
                                <div class="text-muted small">@FormatFileSize(selectedFileSize)</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="upload-placeholder">
                            <span class="upload-placeholder-icon">⬆</span>
                            <span class="small text-muted">Click to select a <code>.zip</code> file</span>
                        </div>
                    }
                </div>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mb-4">@errorMessage</div>
            }

            <button type="submit"
                    class="btn btn-primary w-100"
                    disabled="@(fileBytes == null || string.IsNullOrWhiteSpace(projectName) || isLoading)">
                Upload &amp; scan
            </button>

        </form>
    }
</div>

@code {
    private const long MaxFileSize = 100 * 1024 * 1024;

    private string   projectName      = string.Empty;
    private byte[]?  fileBytes;
    private string   selectedFileName = string.Empty;
    private long     selectedFileSize;
    private bool     isLoading;
    private string   errorMessage     = string.Empty;
    private Guid     uploadedProjectId;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        errorMessage      = string.Empty;
        uploadedProjectId = Guid.Empty;

        var file = e.File;

        if (file.ContentType != "application/zip" && !file.Name.EndsWith(".zip"))
        {
            errorMessage = "Only ZIP archives (.zip) are supported.";
            fileBytes    = null;
            return;
        }

        if (file.Size > MaxFileSize)
        {
            errorMessage = $"File is too large. Maximum is 100 MB (yours: {FormatFileSize(file.Size)}).";
            fileBytes    = null;
            return;
        }

        using var stream = file.OpenReadStream(MaxFileSize);
        using var ms     = new MemoryStream();
        await stream.CopyToAsync(ms);

        fileBytes        = ms.ToArray();
        selectedFileName = file.Name;
        selectedFileSize = file.Size;
    }

    private async Task HandleUploadProject()
    {
        if (fileBytes is null || string.IsNullOrWhiteSpace(projectName))
            return;

        try
        {
            isLoading    = true;
            errorMessage = string.Empty;

            var result = await ApiClient.UploadProjectAsync(projectName.Trim(), fileBytes, selectedFileName);
            Nav.NavigateTo($"projects/{result.ProjectId}/scans");
        }
        catch (Exception ex)
        {
            errorMessage = $"Upload failed: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ResetForm()
    {
        projectName      = string.Empty;
        fileBytes        = null;
        selectedFileName = string.Empty;
        selectedFileSize = 0;
        errorMessage     = string.Empty;
        uploadedProjectId = Guid.Empty;
    }

    private static string FormatFileSize(long bytes) => bytes switch
    {
        < 1024        => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        _             => $"{bytes / (1024.0 * 1024):F1} MB"
    };
}
