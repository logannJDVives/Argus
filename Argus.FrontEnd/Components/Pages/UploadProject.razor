@page "/upload"
@using Argus.Sdk
@using System.IO
@inject ArgusApiClient ApiClient

<div class="upload-container" style="max-width: 500px; margin: 20px auto;">
    <h2>Upload Project</h2>

    @if (isLoading)
    {
        <div style="padding: 20px; text-align: center;">
            <p>📤 Uploading project...</p>
            <p style="font-size: 12px; color: #666;">Please wait...</p>
        </div>
    }
    else
    {
        <form @onsubmit="HandleUploadProject">
            <!-- Project Name Input -->
            <div style="margin-bottom: 15px;">
                <label for="projectName" style="display: block; margin-bottom: 5px; font-weight: bold;">
                    Project Name
                </label>
                <input 
                    type="text" 
                    id="projectName" 
                    @bind="projectName"
                    placeholder="Enter project name"
                    maxlength="100"
                    disabled="@isLoading"
                    style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;"
                />
            </div>

            <!-- File Input -->
            <div style="margin-bottom: 15px;">
                <label for="zipFile" style="display: block; margin-bottom: 5px; font-weight: bold;">
                    ZIP File (max 50MB)
                </label>
                <InputFile 
                    id="zipFile" 
                    OnChange="HandleFileSelected" 
                    accept=".zip"
                    disabled="@isLoading"
                    style="display: block; padding: 8px; border: 1px solid #ccc; border-radius: 4px;"
                />
                @if (fileBytes != null)
                {
                    <div style="margin-top: 8px; font-size: 12px; color: #666;">
                        ✓ Selected: @selectedFileName (@FormatFileSize(selectedFileSize))
                    </div>
                }
            </div>

            <!-- Error Message -->
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div style="padding: 10px; margin-bottom: 15px; background-color: #fee; border: 1px solid #f99; border-radius: 4px; color: #c00;">
                    <strong>❌ Error:</strong> @errorMessage
                </div>
            }

            <!-- Success Message -->
            @if (uploadedProjectId != Guid.Empty)
            {
                <div style="padding: 10px; margin-bottom: 15px; background-color: #efe; border: 1px solid #9f9; border-radius: 4px; color: #060;">
                    <strong>✅ Success!</strong> Project ID: <code>@uploadedProjectId</code>
                    <button type="button" @onclick="ResetForm" style="margin-top: 10px; padding: 5px 10px; background: #060; color: white; border: none; border-radius: 3px; cursor: pointer;">
                        Upload Another
                    </button>
                </div>
            }

            <!-- Submit Button -->
            <button 
                type="submit" 
                disabled="@(fileBytes == null || string.IsNullOrWhiteSpace(projectName) || isLoading)"
                style="width: 100%; padding: 10px; background-color: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 14px; font-weight: bold;"
            >
                @(isLoading ? "Uploading..." : "Upload Project")
            </button>
        </form>
    }
</div>

@code {
    private const long MaxFileSize = 50 * 1024 * 1024; // 50MB

    private string projectName = "";
    private byte[] fileBytes;
    private string selectedFileName = "";
    private long selectedFileSize = 0;
    private bool isLoading = false;
    private string errorMessage = "";
    private Guid uploadedProjectId = Guid.Empty;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        errorMessage = "";
        uploadedProjectId = Guid.Empty;

        var file = e.File;

        // Validate file
        if (file.ContentType != "application/zip" && !file.Name.EndsWith(".zip"))
        {
            errorMessage = "File must be a ZIP archive (.zip)";
            fileBytes = null;
            selectedFileName = "";
            selectedFileSize = 0;
            return;
        }

        if (file.Size > MaxFileSize)
        {
            errorMessage = $"File is too large. Maximum size is 50MB, your file is {FormatFileSize(file.Size)}";
            fileBytes = null;
            selectedFileName = "";
            selectedFileSize = 0;
            return;
        }

        using var readStream = file.OpenReadStream(MaxFileSize);
        using var ms = new MemoryStream();
        await readStream.CopyToAsync(ms);

        fileBytes = ms.ToArray();
        selectedFileName = file.Name;
        selectedFileSize = file.Size;
    }

    private async Task HandleUploadProject()
    {
        // Validation
        if (fileBytes == null)
        {
            errorMessage = "Please select a file";
            return;
        }

        if (string.IsNullOrWhiteSpace(projectName))
        {
            errorMessage = "Please enter a project name";
            return;
        }

        try
        {
            isLoading = true;
            errorMessage = "";
            uploadedProjectId = Guid.Empty;

            uploadedProjectId = await ApiClient.UploadProjectAsync(projectName.Trim(), fileBytes, selectedFileName);
        }
        catch (ArgumentException ex)
        {
            errorMessage = $"Validation error: {ex.Message}";
        }
        catch (HttpRequestException ex)
        {
            errorMessage = $"API error: {ex.Message}. Make sure the backend is running.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Upload failed: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ResetForm()
    {
        projectName = "";
        fileBytes = null;
        selectedFileName = "";
        selectedFileSize = 0;
        errorMessage = "";
        uploadedProjectId = Guid.Empty;
    }

    private string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F2} KB";
        return $"{bytes / (1024.0 * 1024):F2} MB";
    }
}
